{
  "name": "@sql-sandbox/db",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./schema": {
      "types": "./src/schema.d.ts",
      "default": "./src/schema.js"
    },
    "./connection": {
      "types": "./src/connection.d.ts",
      "default": "./src/connection.js"
    }
  },
  "scripts": {
    "build": "tsc --noEmit",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "push": "drizzle-kit push",
    "studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.28.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.7.0"
  }
}
