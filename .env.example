# PostgreSQL - System DB (metadata, query history, etc.)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sql_sandbox

# PostgreSQL - Sandbox connections (workspace schemas live here)
SANDBOX_DB_URL=postgresql://sandbox_user:sandbox_pass@localhost:5432/sql_sandbox

# Redis (BullMQ job queue)
REDIS_URL=redis://:redis_secret@localhost:6379
REDIS_PASSWORD=redis_secret

# LLM API (Phase 8 - AI Optimizer)
LLM_PROVIDER=openrouter
LLM_MODEL=deepseek/deepseek-chat
LLM_API_KEY=

# CORS
CORS_ORIGIN=http://localhost:3000

# App
API_PORT=3001
WEB_PORT=3000
NODE_ENV=development
